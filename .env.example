# GitHub Models (LLM)
GITHUB_TOKEN=
AZURE_MODEL_DEPLOYMENT=gpt-4o-mini

# eBay Browse API (developer.ebay.com -> your application keys)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=SANDBOX

# Etsy Open API v3 (vintage mode) — personal-access keystring, no OAuth
ETSY_API_KEY=

# Infrastructure (these defaults match Kubernetes service names;
# docker-compose overrides REDIS_HOST/DATABASE_URL to its own hostnames)
DATABASE_URL=postgresql://resellid:resellid@postgres-service:5432/resellid
REDIS_HOST=redis-service

GITHUB_USERNAME=ApurboBarua17
